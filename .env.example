# ─── Supabase ────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# ─── Auth / Sessions ─────────────────────────────────────────────────────────
JWT_SECRET=random-32-char-secret
NODE_ENV=development
DEV_ADMIN_ENABLED=false
LOCAL_ADMIN_EMAIL=admin@handypioneers.com
OWNER_EMAIL=admin@handypioneers.com

# ─── Stripe ──────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Twilio ──────────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+1...

# ─── Gmail (OAuth) ───────────────────────────────────────────────────────────
GMAIL_CLIENT_ID=...
GMAIL_CLIENT_SECRET=...
GMAIL_REDIRECT_URI=http://localhost:3000/api/gmail/oauth/callback

# ─── Anthropic (Claude AI — estimates, scope rewriting) ──────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Google Maps ─────────────────────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=AIza...

# ─── Resend (Email Notifications) ────────────────────────────────────────────
RESEND_API_KEY=re_...

# ─── Portal ──────────────────────────────────────────────────────────────────
PORTAL_BASE_URL=https://client.handypioneers.com
PORTAL_ORIGIN=https://client.handypioneers.com

# ─── Client-side (Vite) ─────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ─── Optional ────────────────────────────────────────────────────────────────
PORT=3000
GOOGLE_REVIEW_URL=https://g.page/r/handypioneers/review
FUNNEL_ORIGIN=https://360.handypioneers.com
